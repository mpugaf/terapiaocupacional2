# =============================================================================
# Variables de entorno para features futuras
# Copiar este archivo a .env.local y completar los valores antes de activar el flag
# Ver README.md → "Roadmap de features" para instrucciones paso a paso
# =============================================================================

# --- WhatsApp Button (features.whatsapp = true) ---
# Número completo con código de país, sin espacios ni guiones
# Ejemplo Argentina: 5491112345678
NEXT_PUBLIC_WHATSAPP_NUMBER=

# --- Formulario de Contacto (features.contactForm = true) ---
# Opción A: Formspree — gratuito hasta 50 envíos/mes, sin backend propio
NEXT_PUBLIC_FORMSPREE_ENDPOINT=
# Opción B: EmailJS
NEXT_PUBLIC_EMAILJS_SERVICE_ID=
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=

# --- Google Maps (features.map = true) ---
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
# Coordenadas del consultorio (también en src/content/site.ts → metadata.coordinates)
NEXT_PUBLIC_MAP_LAT=
NEXT_PUBLIC_MAP_LNG=

# --- Agenda Online (features.booking = true) ---
# URL del widget cal.com o Calendly
NEXT_PUBLIC_BOOKING_URL=

# --- Blog con CMS (features.blog = true) ---
# Opción Notion
NOTION_API_KEY=
NOTION_DATABASE_ID=
# Opción Sanity
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_TOKEN=
